{
  "name": "initup",
  "version": "1.0.0",
  "description": "initup — the deterministic hands your AI agent uses to touch your project. Install + patch + generate a technology as one idempotent, reversible operation. CLI command: `initup`.",
  "keywords": [
    "cli",
    "ai",
    "agent",
    "mcp",
    "scaffold",
    "scaffolding",
    "plugins",
    "codemod",
    "project-generator",
    "monorepo",
    "developer-tools"
  ],
  "license": "MIT",
  "author": "Krishnesh Mishra",
  "homepage": "https://github.com/Krishnesh-Mishra/initup#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krishnesh-Mishra/initup.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Krishnesh-Mishra/initup/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "initup": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.26.3",
    "@babel/traverse": "^7.26.4",
    "@babel/types": "^7.26.3",
    "@clack/prompts": "^1.7.0",
    "cac": "^7.0.0",
    "esbuild": "^0.24.2",
    "jsonc-parser": "^3.3.1",
    "magicast": "^0.3.5",
    "picocolors": "^1.1.1",
    "recast": "^0.23.9",
    "semver": "^7.6.3",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@initup/core": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
